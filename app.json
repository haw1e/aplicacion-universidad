{
  "expo": {
    "name": "FastNotes",
    "slug": "fastnotes",
    "version": "1.0.5",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "fastnotes",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "package": "com.haw1e.fastnotes",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF5F7",
          "image": "./assets/images/icon.png",
          "imageWidth": 150,
          "resizeMode": "contain"
        }
      ],
      "expo-secure-store",
      [
        "react-native-android-widget/app.plugin",
        {
          "widgets": [
            {
              "name": "CalendarWidgetPhone",
              "label": "FastNotes Agenda (Móvil)",
              "minWidth": "180dp",
              "minHeight": "180dp",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            },
            {
              "name": "CalendarWidgetTablet",
              "label": "FastNotes Agenda (Tablet)",
              "minWidth": "320dp",
              "minHeight": "180dp",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a3eefcee-f20f-465f-933a-ba69d251b14c"
      }
    },
    "owner": "haw1es-organization"
  }
}
